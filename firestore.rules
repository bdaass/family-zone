rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

  function isSignedIn() {
    return request.auth != null;
  }

  function userDocPath() {
    return /databases/$(database)/documents/users/$(request.auth.uid);
  }

  function userExists() {
    return isSignedIn() && exists(userDocPath());
  }

  function userData() {
    return get(userDocPath()).data;
  }

  function isAdmin() {
    return userExists() && userData().role == 'admin';
  }

  function isEmployee() {
    return userExists() && userData().role == 'employee';
  }

  function isStaff() {
    return isAdmin() || isEmployee();
  }

  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

  function isPublicProduct(data) {
    return data.visibility == true
      && (!('approved' in data) || data.approved != false);
  }

  function onlyFieldsChanged(allowed) {
    return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
  }

  function employeeChangedModerationFields() {
    return request.resource.data.diff(resource.data).affectedKeys().hasAny(['visibility', 'approved']);
  }

  // ── Users ────────────────────────────────────────────────────────────────
  match /users/{userId} {
    allow read: if isOwner(userId);

    allow create: if isOwner(userId)
      && request.resource.data.uid == userId
      && request.resource.data.role == 'client';

    // Users may update cart / favorites / profile fields, but never their role.
    allow update: if isOwner(userId)
      && request.resource.data.uid == resource.data.uid
      && request.resource.data.role == resource.data.role;

    allow delete: if false;
  }

  // ── Products ─────────────────────────────────────────────────────────────
  match /products/{productId} {
    allow read: if isPublicProduct(resource.data)
      || (userExists() && isStaff());

    allow create: if isStaff()
      && request.resource.data.productId == productId
      && request.resource.data.title is string
      && request.resource.data.title.size() > 0
      && request.resource.data.price is number
      && request.resource.data.price >= 0
      && request.resource.data.visibility is bool
      && request.resource.data.approved is bool;

    allow delete: if isAdmin();

    allow update: if isAdmin()
      || (isEmployee() && !employeeChangedModerationFields())
      || (isSignedIn() && onlyFieldsChanged(['favoriteCount']));

  }

  // ── Contact form ─────────────────────────────────────────────────────────
  match /contact_messages/{messageId} {
    allow read: if isStaff();

    allow create: if request.resource.data.message is string
      && request.resource.data.message.size() > 0
      && request.resource.data.message.size() <= 2000
      && request.resource.data.anonymous is bool
      && (
        !('userId' in request.resource.data)
        || request.resource.data.userId == null
        || (isSignedIn() && request.resource.data.userId == request.auth.uid)
      );

    allow update, delete: if isAdmin();
  }

  }
}
