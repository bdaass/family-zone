rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

  function isSignedIn() {
    return request.auth != null;
  }

  function userDocPath() {
    return /databases/$(database)/documents/users/$(request.auth.uid);
  }

  function userExists() {
    return isSignedIn() && exists(userDocPath());
  }

  function userData() {
    return get(userDocPath()).data;
  }

  // Role from JWT custom claims (synced by syncUserRoleToClaims / syncMyRoleClaims).
  function authRole() {
    return isSignedIn() ? request.auth.token.get('role', '') : '';
  }

  // Role from Firestore users/{uid}.role (source of truth).
  function firestoreRole() {
    return userExists() ? userData().get('role', '') : '';
  }

  function isAdmin() {
    return isSignedIn()
      && (authRole() == 'admin' || firestoreRole() == 'admin');
  }

  function isEmployee() {
    return isSignedIn()
      && (authRole() == 'employee' || firestoreRole() == 'employee');
  }

  function isStaff() {
    return isAdmin() || isEmployee();
  }

  // Product writes use Firestore role only (matches StaffStorageAuth + storage.rules).
  function isStaffFromFirestore() {
    return firestoreRole() in ['admin', 'employee'];
  }

  function staffCreateProductAllowed() {
    return (firestoreRole() == 'admin' && adminCreateProduct())
      || (firestoreRole() == 'employee' && employeeCreateProduct());
  }

  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

  function isPublicProduct(data) {
    return data.visibility == true
      && (!('approved' in data) || data.approved != false);
  }

  function canReadProduct() {
    return isStaff()
      || (resource != null && isPublicProduct(resource.data));
  }

  function onlyFieldsChanged(allowed) {
    return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
  }

  function employeeChangedModerationFields() {
    return request.resource.data.diff(resource.data).affectedKeys().hasAny(['visibility', 'approved']);
  }

  function isPublishedProduct() {
    return resource.data.visibility == true
      && (!('approved' in resource.data) || resource.data.approved != false);
  }

  function validProductCreate(id) {
    return request.resource.data.productId == id
      && request.resource.data.title is string
      && request.resource.data.title.size() > 0
      && request.resource.data.description is string
      && request.resource.data.description.size() > 0
      && (request.resource.data.price is int || request.resource.data.price is float)
      && request.resource.data.price >= 0
      && request.resource.data.visibility is bool
      && request.resource.data.approved is bool;
  }

  function adminCreateProduct() {
    return request.resource.data.approved == true
      && request.resource.data.visibility == true;
  }

  function employeeCreateProduct() {
    return request.resource.data.approved == false
      && request.resource.data.visibility == false;
  }

  function employeePendingEditUpdate() {
    return isEmployee()
      && isPublishedProduct()
      && onlyFieldsChanged(['pendingEdit', 'editPending', 'pendingEditAt', 'pendingEditBy', 'needsApproval'])
      && request.resource.data.editPending == true
      && request.resource.data.needsApproval == true;
  }

  function employeeUnpublishedUpdate() {
    return isEmployee()
      && !isPublishedProduct()
      && !employeeChangedModerationFields();
  }

  function employeeStaffNotesUpdate() {
    return isEmployee()
      && isPublishedProduct()
      && onlyFieldsChanged(['staffNotes'])
      && request.resource.data.staffNotes is string;
  }

  function employeeImageColorsUpdate() {
    return isEmployee()
      && isPublishedProduct()
      && onlyFieldsChanged(['imageColors']);
  }

  function favoriteCountDeltaValid() {
    let oldCount = resource.data.get('favoriteCount', 0);
    let newCount = request.resource.data.favoriteCount;
    return newCount >= 0
      && (newCount == oldCount + 1 || newCount == oldCount - 1);
  }

  function viewCountDeltaValid() {
    let oldCount = resource.data.get('viewCount', 0);
    let newCount = request.resource.data.viewCount;
    return newCount >= 0 && newCount == oldCount + 1;
  }

  // ── Internal rate-limit docs (Cloud Functions only) ──────────────────────
  match /_rate_limits/{docId} {
    allow read, write: if false;
  }

  // ── Users ────────────────────────────────────────────────────────────────
  match /users/{userId} {
    allow read: if isOwner(userId);

    allow create: if isOwner(userId)
      && request.resource.data.uid == userId
      && request.resource.data.role == 'client';

    allow update: if isOwner(userId)
      && request.resource.data.uid == resource.data.uid
      && request.resource.data.role == resource.data.role;

    allow delete: if false;
  }

  // ── Products ─────────────────────────────────────────────────────────────
  match /products/{productId} {
    allow read: if canReadProduct();

    allow create: if isStaffFromFirestore()
      && validProductCreate(productId)
      && staffCreateProductAllowed();

    allow delete: if isAdmin();

    allow update: if isAdmin()
      || employeePendingEditUpdate()
      || employeeStaffNotesUpdate()
      || employeeImageColorsUpdate()
      || employeeUnpublishedUpdate()
      || (isSignedIn()
        && onlyFieldsChanged(['favoriteCount'])
        && favoriteCountDeltaValid())
      || (onlyFieldsChanged(['viewCount']) && viewCountDeltaValid());

  }

  // ── Contact form (writes via Cloud Function only) ────────────────────────
  match /contact_messages/{messageId} {
    allow read: if isStaff();

    allow create: if false;

    allow update, delete: if isAdmin();
  }

  // ── Mobile app version (public read for force-update checks) ─────────────
  match /app_config/{docId} {
    allow read: if true;
    allow write: if false;
  }

  }
}
