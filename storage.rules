rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return isSignedIn() && firestore.exists(userDocPath());
    }

    function authRole() {
      return isSignedIn() ? request.auth.token.get('role', '') : '';
    }

    function firestoreRole() {
      return userExists() ? firestore.get(userDocPath()).data.get('role', '') : '';
    }

    function isAdmin() {
      return isSignedIn()
        && (authRole() == 'admin' || firestoreRole() == 'admin');
    }

    function isStaff() {
      return isSignedIn()
        && (authRole() in ['admin', 'employee']
          || firestoreRole() in ['admin', 'employee']);
    }

    function isValidProductImage() {
      return request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg';
    }

    function isValidSliderImage() {
      return request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg';
    }

    match /product_images/{productId}/{fileName} {
      // Product photos are public. Barcodes are staff-only (employees must read after upload).
      allow read: if fileName != 'barcode.jpg' || isStaff();

      allow create: if isStaff()
        && isValidProductImage()
        && (fileName.matches('^[0-9]+\\.jpg$') || fileName == 'barcode.jpg');

      allow update: if isStaff()
        && isValidProductImage()
        && (fileName.matches('^[0-9]+\\.jpg$') || fileName == 'barcode.jpg');

      allow delete: if isAdmin();
    }

    match /product_images/{fileName} {
      allow read: if true;

      allow create: if isStaff()
        && isValidProductImage()
        && fileName.matches('^[A-Za-z0-9]+\\.jpg$');

      allow update: if isStaff() && isValidProductImage();

      allow delete: if isAdmin();
    }

    match /topSlider/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff() && isValidSliderImage();
    }

    match /web/topSlider/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff() && isValidSliderImage();
    }

  }
}
